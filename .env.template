# AI Trading Competition - Environment Variables
# Copy this file to .env and fill in your credentials

# Alpaca Paper Trading - Claude Account
CLAUDE_ALPACA_API_KEY=your_claude_alpaca_api_key
CLAUDE_ALPACA_SECRET_KEY=your_claude_alpaca_secret_key

# Alpaca Paper Trading - Grok Account
GROK_ALPACA_API_KEY=your_grok_alpaca_api_key
GROK_ALPACA_SECRET_KEY=your_grok_alpaca_secret_key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Grok API (xAI)
XAI_API_KEY=your_xai_api_key

# Alpaca Base URL (paper trading)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Learning System (PostgreSQL - Neon recommended)
# Sign up at https://neon.tech for free serverless PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/tradingbot
LEARNING_ENABLED=true
SIGNIFICANT_PNL_THRESHOLD=50.0
MAX_LEARNINGS_PER_RECALL=10
